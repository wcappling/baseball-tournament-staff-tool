# Required on hosted deployments (Railway prod)
STAFF_TOOL_PASSWORD=replace-with-a-long-shared-password

# Admin account password — set this on Railway to enable logging in as the
# admin account (team code "default"). Without it, the Admin tab is inaccessible.
ADMIN_PASSWORD=replace-with-a-strong-admin-password
SESSION_SECRET=replace-with-a-random-32-plus-character-secret
STAFF_TOOL_DATA_DIR=/data

# Recommended on hosted deployments
STAFF_TOOL_HOSTED=true
STAFF_TOOL_ENABLE_HOSTED_JOBS=true

# Dev only — bypasses the login screen entirely; never set on prod
# DEV_AUTO_LOGIN=true

# Optional — comma-separated list of additional CORS origins beyond localhost.
# Railway deployments auto-detect their own URL via RAILWAY_STATIC_URL.
# Only needed for custom domains pointed at the app.
# ALLOWED_ORIGINS=https://your-custom-domain.com
